# Port du serveur (défaut : 3000)
PORT=3000

# Clé API Resend (https://resend.com)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx

# Email de destination (celui qui reçoit les prospects)
TO_EMAIL=contact@votreagence.fr

# Email expéditeur (doit être un domaine vérifié dans Resend)
FROM_EMAIL=questionnaire@votreagence.fr

# Nom de l'agence (utilisé dans les emails)
AGENCY_NAME=astr.studio

# Taille maximale par fichier en Mo (défaut : 10)
MAX_FILE_SIZE_MB=10
